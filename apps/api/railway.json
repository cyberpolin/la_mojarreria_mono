{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "buildCommand": "npm run build && echo 'Build completed!'"
  },
  "deploy": {
    "startCommand": "npm run migrate:prod && npm run seed:prod && npm run start",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
