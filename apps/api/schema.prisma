  closedById            String?          @map("closedBy") @postgresql.Uuid
  createdAt             DateTime?        @default(now())
  updatedAt             DateTime?        @updatedAt

  @@index([closedById])
}

model DailyCloseItem {
  id        String      @id @default(uuid()) @postgresql.Uuid
