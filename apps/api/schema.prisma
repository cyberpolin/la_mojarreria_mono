  grossMarginBps        Int              @default(0)
  costingWarnings       Json?
  costingStatus         String           @default("PENDING")
  notes                 String           @default("")
  status                String           @default("ACTIVE")
  items                 DailyCloseItem[] @relation("DailyCloseItem_close")
  sourceRaw             DailyCloseRaw?   @relation("DailyClose_sourceRaw", fields: [sourceRawId], references: [id])
  sourceRawId           String?          @unique @map("sourceRaw") @postgresql.Uuid
